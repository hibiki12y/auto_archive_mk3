{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${TEMPLATESTAY_CODEX_HOOK}"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${TEMPLATESTAY_CODEX_HOOK}"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|Read|Edit|Write|WebFetch|WebSearch|apply_patch|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${TEMPLATESTAY_CODEX_HOOK}"
          }
        ]
      }
    ]
  }
}
