{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "opus",
  "effortLevel": "xhigh",
  "autoMemoryEnabled": false,
  "enabledMcpjsonServers": [
    "memory",
    "context-manager",
    "document-parser",
    "codex-gateway",
    "gemini-gateway"
  ],
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(python3 -m pytest:*)",
      "WebFetch",
      "WebSearch"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(npm publish:*)",
      "Bash(yarn publish:*)",
      "Bash(pnpm publish:*)",
      "Bash(gh release:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./**/*.pem)",
      "Read(./**/id_rsa*)",
      "Bash(rm -rf:*)",
      "Bash(sudo:*)"
    ]
  }
}
