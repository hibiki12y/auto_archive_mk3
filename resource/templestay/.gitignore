# Python caches
__pycache__/
*.pyc
.pytest_cache/

# IDE / OS
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# Secrets
.env
.env.local

# Local Claude/Codex per-user state (gitignored by convention)
.claude/settings.local.json

# Defensive: literal directories created by clients that fail to interpolate
# `${VAR}` env-block tokens in `.mcp.json` (the memory MCP server now refuses
# such values, but earlier sessions could leave `${TEMPLATESTAY_MEMORY_ROOT}/`
# behind under the repo root).
${TEMPLATESTAY_MEMORY_ROOT}/
${MEMORY_V2_ROOT}/

# Codex CLI session sentinel. The CLI drops a zero-byte `.codex` marker
# (sometimes a `.codex/` directory) into whichever cwd it runs against.
# It is not work product — codex-gateway already filters it out of the
# validated diff via `_is_ephemeral_codex_path`; this entry just keeps
# the file from polluting `git status` for developers who run codex in
# the templestay checkout root.
/.codex
/.codex/
