# Required: Discord smoke/service
AUTO_ARCHIVE_DISCORD_TOKEN=
AUTO_ARCHIVE_DISCORD_APPLICATION_ID=
AUTO_ARCHIVE_DISCORD_BOT_USER_ID=
AUTO_ARCHIVE_DISCORD_GUILD_ID=
AUTO_ARCHIVE_DISCORD_CHANNEL_ID=
AUTO_ARCHIVE_E2E_TEST_CHANNEL_ID=
AUTO_ARCHIVE_DISCORD_MESSAGE_CONTENT_INTENT=
AUTO_ARCHIVE_DISCORD_CONTEXT_HISTORY=
AUTO_ARCHIVE_DISCORD_CONTEXT_HISTORY_BACKFILL=
AUTO_ARCHIVE_DISCORD_CONTEXT_HISTORY_LIMIT=
AUTO_ARCHIVE_DISCORD_CONTEXT_HISTORY_MAX_ENTRIES=
AUTO_ARCHIVE_DISCORD_CONTEXT_HISTORY_BACKFILL_LIMIT=
AUTO_ARCHIVE_DISCORD_NATURAL_LANGUAGE_TRIGGER_MODE=
AUTO_ARCHIVE_DISCORD_NATURAL_LANGUAGE_PREFIXES=
AUTO_ARCHIVE_DISCORD_TASK_CPU_CORES=
AUTO_ARCHIVE_DISCORD_TASK_MEMORY_MIB=
AUTO_ARCHIVE_DISCORD_TASK_WALL_TIME_SEC=
AUTO_ARCHIVE_DISCORD_TASK_GPU_CARDS=
AUTO_ARCHIVE_DISCORD_TASK_WORKING_DIRECTORY=
AUTO_ARCHIVE_DISCORD_TASK_ARTIFACT_LOCATION=
AUTO_ARCHIVE_CONTROL_LEDGER_PATH=
AUTO_ARCHIVE_DISCORD_AUTH_DB_PATH=
AUTO_ARCHIVE_DISCORD_AUTH_DB_MODE=
AUTO_ARCHIVE_DISCORD_AUTH_DB_DRIVER=
AUTO_ARCHIVE_DISCORD_AUTH_DB_PYTHON_BIN=
AUTO_ARCHIVE_DISCORD_AUTH_DB_SQLITE_BIN=
AUTO_ARCHIVE_DISCORD_ALLOWED_USER_IDS=
AUTO_ARCHIVE_DISCORD_ALLOWED_CHANNEL_IDS=
AUTO_ARCHIVE_DISCORD_ADMIN_USER_IDS=
AUTO_ARCHIVE_DISCORD_ENABLE_DMS=
AUTO_ARCHIVE_DISCORD_ALLOW_BOTS=

# Optional: control-plane OpenTelemetry OTLP HTTP logs export.
# Default off. Set AUTO_ARCHIVE_OTEL_LOGS_URL to an OTLP HTTP /v1/logs
# collector endpoint to mirror safe control-plane event metadata. Raw Discord
# content, task instructions, and free-form reasons are never exported.
# AUTO_ARCHIVE_OTEL_RESOURCE_ATTRIBUTES uses comma-separated key=value pairs.
AUTO_ARCHIVE_OTEL_LOGS_URL=
AUTO_ARCHIVE_OTEL_RESOURCE_ATTRIBUTES=

# Optional: in-flight task health observer. Default off because stall
# thresholds must be calibrated per runtime/provider/site. When set to a
# positive integer, the Discord service wires a TaskStallObserver into Plana
# and /doctor shows current in-flight stall problems on demand.
# Set AUTO_ARCHIVE_TASK_STALL_LEDGER_TICK_INTERVAL_MS to a positive integer to
# periodically write safe task.health_stalled events to the control ledger
# for /feed inspection. This does not push Discord alerts by itself.
AUTO_ARCHIVE_TASK_STALL_THRESHOLD_MS=
AUTO_ARCHIVE_TASK_STALL_LEDGER_TICK_INTERVAL_MS=

# Optional: read-only task health retained evidence in /doctor.
# Default off. Point this at the operator-owned control-plane JSONL ledger
# containing task.health_stalled events to show retained stall-event scorecard
# health without ticking observers, writing control-plane events, mutating
# ledgers, contacting services, or rendering raw task/correlation ids.
# MAX_LEDGER_BYTES is a positive safe integer replay guard; unset uses 10 MiB.
AUTO_ARCHIVE_TASK_HEALTH_EVIDENCE_LEDGER_PATH=
AUTO_ARCHIVE_TASK_HEALTH_EVIDENCE_MAX_LEDGER_BYTES=

# Optional: read-only task archive/unarchive retained evidence in /doctor.
# Default off. Point this at the operator-owned control-plane JSONL ledger
# containing task.archived/task.unarchived archiveAudit records to show
# retained archive UX scorecard health without mutating archive state,
# writing or rotating ledgers, contacting Discord/GitLab/provider services,
# or rendering raw task/user/channel ids, reasons, instructions, or payloads.
# MAX_LEDGER_BYTES is a positive safe integer replay guard; unset uses 10 MiB.
AUTO_ARCHIVE_TASK_ARCHIVE_EVIDENCE_LEDGER_PATH=
AUTO_ARCHIVE_TASK_ARCHIVE_EVIDENCE_MAX_LEDGER_BYTES=

# Optional: read-only subagent operator retained evidence in /doctor.
# Default off. Point this at the operator-owned roster-event JSONL ledger
# containing subagent.spawned/completed/aborted/failed and roster.progress
# events to show retained subagent lifecycle scorecard health without
# spawning, steering, killing, reading live subagents, mutating ledgers, or
# rendering raw subagent/task/runtime ids, messages, artifacts, or payloads.
# MAX_LEDGER_BYTES is a positive safe integer replay guard; unset uses 10 MiB.
AUTO_ARCHIVE_SUBAGENT_OPERATOR_EVIDENCE_LEDGER_PATH=
AUTO_ARCHIVE_SUBAGENT_OPERATOR_EVIDENCE_MAX_LEDGER_BYTES=

# Optional: read-only focus/session binding retained evidence in /doctor.
# Default off. Point this at the operator-owned control-plane JSONL ledger
# containing session.binding_* and steering.submitted bindingAudit records to
# show focus/steering lifecycle scorecard health without focusing, unfocusing,
# steering, contacting services, mutating ledgers, or rendering raw binding,
# task, owner, guild/channel/thread, subagent, instruction, or payload values.
# bindingAudit hashes are domain-separated HMAC digests. Leave the pepper unset
# or blank for process-local random unlinkability across restarts, or set a
# high-entropy deployment pepper only when operators need cross-restart audit
# correlation.
# MAX_LEDGER_BYTES is a positive safe integer replay guard; unset uses 10 MiB.
AUTO_ARCHIVE_SESSION_BINDING_AUDIT_HASH_PEPPER=
AUTO_ARCHIVE_SESSION_BINDING_EVIDENCE_LEDGER_PATH=
AUTO_ARCHIVE_SESSION_BINDING_EVIDENCE_MAX_LEDGER_BYTES=

# Optional: read-only TraitModule scheduler tick evidence in /doctor.
# Default off. Point this at the operator-owned JSONL ledger written by
# runTraitSchedulerTickOnceWithLeaseAndEvidence() to show scorecard health,
# malformed-line counts, and sample-size warnings without running ticks,
# acquiring leases, dispatching jobs, rotating files, or sending Discord pushes.
# MAX_LEDGER_BYTES is a positive safe integer replay guard; unset uses 100 MiB.
AUTO_ARCHIVE_TRAIT_SCHEDULER_TICK_EVIDENCE_LEDGER_PATH=
AUTO_ARCHIVE_TRAIT_SCHEDULER_TICK_EVIDENCE_MAX_LEDGER_BYTES=

# Optional: smoke/service compute-node override
#   smoke: unset, git-clone, or current-node
#   service: unset/slurm-apptainer, git-clone, or current-node
# Production policy: tasks must execute inside slurm+apptainer containment.
# Leave unset (defaults to slurm-apptainer) unless you are running smoke/dev.
AUTO_ARCHIVE_COMPUTE_NODE=

# Required when AUTO_ARCHIVE_COMPUTE_NODE is slurm-apptainer (or unset):
#   - AUTO_ARCHIVE_APPTAINER_IMAGE: SIF or oras://... reference Apptainer
#     should exec the agent-instance entry script inside.
#   - AUTO_ARCHIVE_AGENT_INSTANCE_ENTRY: in-container absolute path to the
#     compiled entry script (typically /opt/auto-archive/dist/runtime/agent-instance-entry.js).
#   - AUTO_ARCHIVE_AGENT_INSTANCE_NODE_BIN: optional override for the
#     in-container `node` binary path. Defaults to bare `node`.
#   - AUTO_ARCHIVE_APPTAINER_CLI_PATH / AUTO_ARCHIVE_SLURM_SALLOC_PATH /
#     AUTO_ARCHIVE_SLURM_SCANCEL_PATH: optional pinned host binary paths.
AUTO_ARCHIVE_APPTAINER_IMAGE=
AUTO_ARCHIVE_AGENT_INSTANCE_ENTRY=/opt/auto-archive/dist/runtime/agent-instance-entry.js
AUTO_ARCHIVE_AGENT_INSTANCE_NODE_BIN=
AUTO_ARCHIVE_APPTAINER_CLI_PATH=
AUTO_ARCHIVE_SLURM_SALLOC_PATH=
AUTO_ARCHIVE_SLURM_SCANCEL_PATH=

# Runtime provider selection (multi-provider-scope.md). One of: codex, claude-agent.
# Unset/blank defaults to 'codex'. Selection is bootstrap-time only; no mid-flight switching.
AUTO_ARCHIVE_RUNTIME_PROVIDER=
AUTO_ARCHIVE_RUNTIME_PROVIDER_EVIDENCE_PATH=
AUTO_ARCHIVE_RUNTIME_PROVIDER_EVIDENCE_MAX_BYTES=

# Optional: built-in methodology TraitModule runtime decoration.
# Unset/off = no decoration. evidence-only/on/1 = ask Plana to admit
# trait.methodology.agent-methodology-origin.v1 and compose its evidence-only
# RuntimeDriver decorator at dispatch time. This does not switch providers.
AUTO_ARCHIVE_METHODOLOGY_TRAIT_RUNTIME_DECORATION=

# Optional: Codex bootstrap (CLI auth is preferred; API key is fallback)
AUTO_ARCHIVE_CODEX_API_KEY=
AUTO_ARCHIVE_CODEX_CLI_PATH=
AUTO_ARCHIVE_CODEX_SETTINGS_FILE=
AUTO_ARCHIVE_CODEX_MODEL=
AUTO_ARCHIVE_CODEX_MODEL_FALLBACK=
AUTO_ARCHIVE_CODEX_REASONING_EFFORT=

# Optional: Claude Agent SDK bootstrap (consulted when AUTO_ARCHIVE_RUNTIME_PROVIDER=claude-agent).
# Production posture: set AUTO_ARCHIVE_ANTHROPIC_API_KEY (env-backed); container should run --bare.
# Dev/local single-user only: AUTO_ARCHIVE_CLAUDE_CLI_PATH may point at a `claude` binary
# that already holds Pro/Max OAuth tokens. Tokens MUST NOT be shared into containers.
AUTO_ARCHIVE_ANTHROPIC_API_KEY=
AUTO_ARCHIVE_CLAUDE_CLI_PATH=
AUTO_ARCHIVE_CLAUDE_MODEL=
AUTO_ARCHIVE_CLAUDE_FALLBACK_MODEL=
AUTO_ARCHIVE_CLAUDE_REASONING_EFFORT=
AUTO_ARCHIVE_CLAUDE_PERMISSION_MODE=
AUTO_ARCHIVE_CLAUDE_MAX_TURNS=
AUTO_ARCHIVE_CLAUDE_MAX_BUDGET_USD=

# Optional: Plana runtime advisor (cross-vendor read-only review).
# When set, Plana consults a second LLM on sampled runtime events to give
# a "different perspective" verdict. Recommended pairing: dispatched task on
# Codex (default), advisor on Claude Agent. Only "claude-agent" is supported
# as advisor provider today. Unset = no advisor (rule-based review only).
# Reuses AUTO_ARCHIVE_ANTHROPIC_API_KEY / AUTO_ARCHIVE_CLAUDE_CLI_PATH for auth.
AUTO_ARCHIVE_PLANA_ADVISOR_PROVIDER=
AUTO_ARCHIVE_PLANA_ADVISOR_MODEL=
AUTO_ARCHIVE_PLANA_ADVISOR_FALLBACK_MODEL=
AUTO_ARCHIVE_PLANA_ADVISOR_MAX_CALLS=
# Optional JSONL evidence ledger for redacted advisor verdict breadcrumbs.
# Records task/instance/event/verdict metadata only; no prompt text, response
# text, free-form veto reason, Discord message content, or raw instruction.
AUTO_ARCHIVE_PLANA_ADVISOR_EVENTS_LEDGER_PATH=
# Optional bounded replay guard used by /doctor for the advisor events ledger.
AUTO_ARCHIVE_PLANA_ADVISOR_EVENTS_MAX_LEDGER_BYTES=

# Persona role binding (operator-facing convention; surfaced by `/config view`).
#   Arona := dispatched-task runtime  (AUTO_ARCHIVE_RUNTIME_PROVIDER)
#   Plana := runtime advisor          (AUTO_ARCHIVE_PLANA_ADVISOR_PROVIDER)
# Recommended baseline 2026-05-07: Arona=codex/gpt-5.5, Plana=claude-agent/claude-opus-4-7.
# Operator may override per-persona settings via Discord `/config set persona:<arona|plana>
# key:<provider|model|effort|max_turns> value:<v>`. Overrides land in
# runtime-state/persona-settings.json and take effect on the next dispatch
# (dispatch-boundary hot-swap; multi-provider-scope.md §1.3.0 / §1.4.0).
# Provider hot-swap for Arona is allowed only when both `codex` and `claude-agent`
# auths are bootstrap-ready; Plana provider hot-swap remains out of scope.

# Optional: GitLab task assignment, work-result recording, and artifact publishing
AUTO_ARCHIVE_GITLAB_ENABLED=
AUTO_ARCHIVE_GITLAB_URL=
AUTO_ARCHIVE_GITLAB_TOKEN_ENV=
AUTO_ARCHIVE_GITLAB_PROJECT_ID=
AUTO_ARCHIVE_GITLAB_ASSIGNMENT_ENABLED=
AUTO_ARCHIVE_GITLAB_AUTO_CREATE_PROJECTS=
AUTO_ARCHIVE_GITLAB_ASSIGNMENT_NAMESPACE_ID=
AUTO_ARCHIVE_GITLAB_ASSIGNMENT_NAMESPACE_PATH=
AUTO_ARCHIVE_GITLAB_ASSIGNMENT_PROJECT_PREFIX=
AUTO_ARCHIVE_GITLAB_ASSIGNMENT_PROJECT_VISIBILITY=
AUTO_ARCHIVE_GITLAB_ASSIGNMENT_INITIALIZE_WITH_README=
AUTO_ARCHIVE_GITLAB_WORK_RESULT_ISSUE_IID=
AUTO_ARCHIVE_GITLAB_WORK_RESULT_LABELS=
AUTO_ARCHIVE_GITLAB_WORK_RESULT_INTERNAL=
AUTO_ARCHIVE_GITLAB_ARTIFACT_PUBLISH_ENABLED=
AUTO_ARCHIVE_GITLAB_ARTIFACT_DESTINATION_PREFIX=
AUTO_ARCHIVE_GITLAB_ARTIFACT_MAX_TOTAL_BYTES=
AUTO_ARCHIVE_GITLAB_ARTIFACT_MAX_FILE_BYTES=
GITLAB_TOKEN=

# Persona — Discord 사용자-facing 메시지를 작은 모델로 다시 쓰기 (Arona/Plana 듀엣)
# Default off. Enable only with AUTO_ARCHIVE_PERSONA_MODE=duet plus a
# persona-scoped AUTO_ARCHIVE_PERSONA_API_KEY. OPENAI_API_KEY fallback is
# disabled unless AUTO_ARCHIVE_PERSONA_ALLOW_OPENAI_API_KEY_FALLBACK=1.
# API key 가 비어 있으면 자동 비활성화 (fail-open). 기본 모델 = gpt-4o-mini.
# 식별자/경로/URL/숫자/라이프사이클 키워드는 프롬프트와 출력 불변식 guard 로 verbatim 보존.
# 변환 실패는 원문을 그대로 전송 (fail-open) — UX 레이어이지 신뢰성 의존성 아님.
# 구조화 출력 (`/tasks`, `/agenda`, `/history`, `/context`, `/auth`, `/doctor`,
# `/help`) 및 terminal/approval/focus/subagent/follow-up reply 는 변환 게이트 우회 — verbatim 보존.
# Default event allowlist: ask-accepted,running-update,status-reply,cancel-ack,access-denied.
AUTO_ARCHIVE_PERSONA_MODE=
AUTO_ARCHIVE_PERSONA_API_KEY=
AUTO_ARCHIVE_PERSONA_ALLOW_OPENAI_API_KEY_FALLBACK=
AUTO_ARCHIVE_PERSONA_EVENT_TYPES=
AUTO_ARCHIVE_PERSONA_MODEL=
AUTO_ARCHIVE_PERSONA_BASE_URL=
AUTO_ARCHIVE_PERSONA_TIMEOUT_MS=
AUTO_ARCHIVE_PERSONA_TEMPERATURE=
AUTO_ARCHIVE_PERSONA_LATENCY_BUDGET_MS=
AUTO_ARCHIVE_PERSONA_SAMPLING_LOG_RATE=
# Optional `/doctor` redacted scorecard over retained persona-transform-observed metadata JSONL.
AUTO_ARCHIVE_PERSONA_TELEMETRY_LEDGER_PATH=
AUTO_ARCHIVE_PERSONA_TELEMETRY_MAX_LEDGER_BYTES=

# Optional `/doctor` redacted scorecard over the Claude token offload metadata-only JSONL ledger.
# The ledger never carries raw prompts/responses; this section is advisory-only and never
# satisfies a live-proof gate by itself.
AUTO_ARCHIVE_CLAUDE_OFFLOAD_LEDGER_PATH=
AUTO_ARCHIVE_CLAUDE_OFFLOAD_MAX_LEDGER_BYTES=

# Operator shell-hook bridge — advanced lifecycle observer surface.
# Default off. Set AUTO_ARCHIVE_SHELL_HOOKS=on only with an audited hook config.
# Set AUTO_ARCHIVE_ACCEPT_HOOKS=1 for explicit non-interactive consent to
# auto-approve configured (event, command) pairs for this process; callers can
# persist the resolved allowlist with saveAllowlist.
AUTO_ARCHIVE_SHELL_HOOKS=
AUTO_ARCHIVE_ACCEPT_HOOKS=
